{
  "info": {
    "name": "RapidRubric API",
    "description": "API collection for RapidRubric (CSCI4177/CSCI5709 Assignment 2).\n\nCovers the three core features — Draft Submission & File Upload, Rubric Builder, and TA Review & Approval Queue — plus the security (auth) endpoints.\n\nSetup:\n1. Set the `baseUrl` collection variable (e.g. your Railway URL or http://localhost:3001).\n2. Run **Auth > Login (instructor)** — it auto-saves `instructorToken`.\n3. Run **Auth > Login (TA)** and **Auth > Login (student)** to populate `taToken` / `studentToken`.\n4. The feature requests below read those tokens automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001" },
    { "key": "instructorToken", "value": "" },
    { "key": "taToken", "value": "" },
    { "key": "studentToken", "value": "" },
    { "key": "rubricId", "value": "" },
    { "key": "assignmentId", "value": "" },
    { "key": "submissionId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth (Security)",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"newuser@test.com\",\n  \"password\": \"Password123!\",\n  \"name\": \"New User\",\n  \"role\": \"student\"\n}" }
          }
        },
        {
          "name": "Login (instructor)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('instructorToken', pm.response.json().access_token);",
                  "  pm.test('instructor logged in', () => pm.expect(pm.response.json().user.role).to.eql('instructor'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"instructor@test.com\",\n  \"password\": \"Password123!\"\n}" }
          }
        },
        {
          "name": "Login (TA)",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["if (pm.response.code === 200) { pm.collectionVariables.set('taToken', pm.response.json().access_token); }"], "type": "text/javascript" }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ta1@test.com\",\n  \"password\": \"Password123!\"\n}" }
          }
        },
        {
          "name": "Login (student)",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["if (pm.response.code === 200) { pm.collectionVariables.set('studentToken', pm.response.json().access_token); }"], "type": "text/javascript" }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"student1@test.com\",\n  \"password\": \"Password123!\"\n}" }
          }
        },
        {
          "name": "Login - wrong password (401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"instructor@test.com\",\n  \"password\": \"wrongpassword\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{instructorToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/logout", "host": ["{{baseUrl}}"], "path": ["api", "auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "Feature 2 - Rubric Builder",
      "item": [
        {
          "name": "Create rubric (201)  [implemented]",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "if (pm.response.code === 201) { pm.collectionVariables.set('rubricId', pm.response.json().id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{instructorToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/rubrics", "host": ["{{baseUrl}}"], "path": ["api", "rubrics"] },
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Argumentative Essay Rubric\",\n  \"criteria\": [\n    { \"name\": \"Thesis & Argument\", \"description\": \"Clear, defensible thesis\", \"max_score\": 25 },\n    { \"name\": \"Structure\", \"description\": \"Logical organization\", \"max_score\": 25 },\n    { \"name\": \"Evidence & Citations\", \"description\": \"Use of sources\", \"max_score\": 25 },\n    { \"name\": \"Grammar & Style\", \"description\": \"Mechanics and clarity\", \"max_score\": 25 }\n  ]\n}" }
          }
        },
        {
          "name": "List rubrics (200)  [implemented]",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('status is 200', () => pm.response.to.have.status(200));", "pm.test('returns an array', () => pm.expect(pm.response.json()).to.be.an('array'));"], "type": "text/javascript" } }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{instructorToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/rubrics", "host": ["{{baseUrl}}"], "path": ["api", "rubrics"] }
          }
        },
        {
          "name": "Get rubric by id (200)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{instructorToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/rubrics/{{rubricId}}", "host": ["{{baseUrl}}"], "path": ["api", "rubrics", "{{rubricId}}"] }
          }
        },
        {
          "name": "Update rubric (200 / 409 if locked)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{instructorToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/rubrics/{{rubricId}}", "host": ["{{baseUrl}}"], "path": ["api", "rubrics", "{{rubricId}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Argumentative Essay Rubric (v2)\"\n}" }
          }
        },
        {
          "name": "Create rubric - NO TOKEN (401)",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('status is 401', () => pm.response.to.have.status(401));"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/rubrics", "host": ["{{baseUrl}}"], "path": ["api", "rubrics"] },
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Should fail\",\n  \"criteria\": [{ \"name\": \"x\", \"max_score\": 10 }]\n}" }
          }
        },
        {
          "name": "Create rubric - WRONG ROLE student (403)",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('status is 403', () => pm.response.to.have.status(403));"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{studentToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/rubrics", "host": ["{{baseUrl}}"], "path": ["api", "rubrics"] },
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Should fail\",\n  \"criteria\": [{ \"name\": \"x\", \"max_score\": 10 }]\n}" }
          }
        },
        {
          "name": "Create rubric - INVALID BODY (400)",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('status is 400', () => pm.response.to.have.status(400));"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{instructorToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/rubrics", "host": ["{{baseUrl}}"], "path": ["api", "rubrics"] },
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"\",\n  \"criteria\": []\n}" }
          }
        }
      ]
    },
    {
      "name": "Feature 1 - Submission",
      "item": [
        {
          "name": "List open assignments (student)",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 200 && pm.response.json()[0]) { pm.collectionVariables.set('assignmentId', pm.response.json()[0].id); }"], "type": "text/javascript" } }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/assignments", "host": ["{{baseUrl}}"], "path": ["api", "assignments"] }
          }
        },
        {
          "name": "Submit assignment (PDF upload)",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) { pm.collectionVariables.set('submissionId', pm.response.json().id); }"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/submissions/{{assignmentId}}", "host": ["{{baseUrl}}"], "path": ["api", "submissions", "{{assignmentId}}"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": [], "description": "A PDF file (<= 10 MB)" },
                { "key": "comments", "value": "First draft for review.", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "List my submissions (student)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/submissions", "host": ["{{baseUrl}}"], "path": ["api", "submissions"] }
          }
        },
        {
          "name": "Get released feedback (student)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/submissions/feedback/{{submissionId}}", "host": ["{{baseUrl}}"], "path": ["api", "submissions", "feedback", "{{submissionId}}"] }
          }
        }
      ]
    },
    {
      "name": "Feature 3 - TA Review",
      "item": [
        {
          "name": "Get review queue (TA)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{taToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/ta/queue", "host": ["{{baseUrl}}"], "path": ["api", "ta", "queue"] }
          }
        },
        {
          "name": "Get submission for review (TA)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{taToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/ta/{{submissionId}}", "host": ["{{baseUrl}}"], "path": ["api", "ta", "{{submissionId}}"] }
          }
        },
        {
          "name": "Edit + release feedback (TA)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{taToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/ta/{{submissionId}}/release", "host": ["{{baseUrl}}"], "path": ["api", "ta", "{{submissionId}}", "release"] },
            "body": { "mode": "raw", "raw": "{\n  \"criteria\": [\n    { \"id\": \"c1\", \"score\": 21, \"feedback\": \"Sharpen your thesis.\" },\n    { \"id\": \"c2\", \"score\": 23, \"feedback\": \"Good structure.\" },\n    { \"id\": \"c3\", \"score\": 16, \"feedback\": \"Add citations.\" },\n    { \"id\": \"c4\", \"score\": 24, \"feedback\": \"Clean writing.\" }\n  ]\n}" }
          }
        }
      ]
    }
  ]
}
